{
  "name": "trading-bot",
  "version": "1.0.0",
  "description": "Automated futures trading bot with Bybit execution and Binance analysis",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "backtest": "ts-node src/backtest/run-backtest.ts",
    "backtest:batch": "ts-node src/backtest/batch-backtest-90d.ts",
    "backtest:compare": "ts-node src/backtest/compare-trend-backtest.ts",
    "clean": "rm -rf dist",
    "report": "ts-node src/utils/dry-run-report.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
