# ============================================
# EXCHANGE SELECTION & API CONFIGURATION
# ============================================
# Trading: bybit = execute orders on Bybit. binance = execute on Binance.
# Analysis: always uses Binance (market data, signals).
EXCHANGE=bybit

# BYBIT API CONFIGURATION (used when EXCHANGE=bybit)
# Testnet: https://testnet.bybit.com | Mainnet: https://www.bybit.com
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=false

# BINANCE API CONFIGURATION (for analysis/data only)
# No keys required for analysis; only needed if EXCHANGE=binance.
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_USE_TESTNET=true

# ============================================
# MARKET REGIME SWITCHING
# ============================================
# Bear market (default): TIMEFRAME=1h, ADX_MIN=32  → ~70% WR, 226% ROI
# Bull market:           TIMEFRAME=4h, ADX_MIN=25  → ~60% WR,  +39% ROI
# Change both values and restart when switching modes.
TIMEFRAME=1h
ADX_MIN=32

# ============================================
# TRADING PARAMETERS
# ============================================
INITIAL_CAPITAL=150              # Starting balance in USDT
RISK_PER_TRADE=3.5               # Risk % per trade
LEVERAGE=15                      # Trading leverage
ENTRY_MODE=aggressive            # aggressive | conservative
MIN_CONFIDENCE=65                # Minimum signal confidence (0-100)
MAX_OPEN_TRADES=5                # Max concurrent positions
CLOSE_AT_TP1=true                # true = close full position at TP1
TAKE_50_AT_TP1_MOVE_SL=false     # true = close 50% at TP1, move SL to entry
TRAILING_STOP=true               # Use trailing stop after TP1
QUOTE_CURRENCY=USDT
DAILY_LOSS_LIMIT=5               # Stop trading if down 5% in a day

# ============================================
# STOP LOSS (ATR-based)
# ============================================
SL_ATR_MULTIPLIER=1.5            # SL distance = ATR × multiplier
SL_ATR_MIN_PCT=1.5               # Minimum SL % (floor)

# ============================================
# TAKE PROFIT
# ============================================
TP1_R_MULT=2.5                   # TP1 at 2.5× the SL distance
TP2_R_MULT=4.0                   # TP2 at 4× the SL distance
TP1_PERCENT=2                    # Minimum TP1 % (floor)
TP2_PERCENT=5                    # Minimum TP2 % (floor)

# ============================================
# DATA REFRESH CYCLE
# ============================================
REFRESH_CYCLE=120000             # Milliseconds between cycles (120s)

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info                   # debug | info | warn | error
LOG_DIR=./logs
VERBOSE_LOGGING=false

# ============================================
# RISK MANAGEMENT
# ============================================
MAX_POSITION_SIZE_PERCENT=5
CORRELATION_THRESHOLD=0.7
MAX_SAME_SECTOR_EXPOSURE=15

# ============================================
# TRADING MODES (START WITH DRY_RUN=true!)
# ============================================
ENABLE_DRY_RUN=true              # true = no real orders (start here)
ENABLE_PAPER_TRADING=false       # true = simulated execution

# ============================================
# NOTIFICATIONS
# ============================================
# Telegram — regime change alerts + daily 7am WIB report + bot commands
# 1. Create bot: https://t.me/BotFather → /newbot → copy token
# 2. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → find "chat":{"id":...}
TELEGRAM_BOT_TOKEN=              # e.g. 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=                # e.g. 987654321

DISCORD_WEBHOOK_URL=             # Optional Discord webhook
