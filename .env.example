# BINANCE API CONFIGURATION
# Testnet: https://testnet.binancefuture.com
# Mainnet: https://fapi.binance.com
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
BINANCE_USE_TESTNET=true

# TRADING PARAMETERS
RISK_PER_TRADE=2
LEVERAGE=5
ENTRY_MODE=aggressive
MIN_CONFIDENCE=80
MAX_OPEN_TRADES=10
CLOSE_AT_TP1=false
TRAILING_STOP=true
QUOTE_CURRENCY=USDT
DAILY_LOSS_LIMIT=3

# POSITION SIZING
# Stop loss distance in percentage (default 2%)
SL_DISTANCE_PCT=2

# TP1 & TP2 profit targets (percentage from entry)
TP1_PERCENT=2
TP2_PERCENT=4

# DATA REFRESH CYCLE (milliseconds)
REFRESH_CYCLE=120000

# LOGGING
LOG_LEVEL=info
LOG_DIR=./logs

# RISK MANAGEMENT
MAX_POSITION_SIZE_PERCENT=5
CORRELATION_THRESHOLD=0.7
MAX_SAME_SECTOR_EXPOSURE=15

# FEATURE FLAGS
ENABLE_PAPER_TRADING=false
ENABLE_DRY_RUN=true
VERBOSE_LOGGING=false
